/// adjust the rectangle position and size
void adjust(Rect roi&, int x, int y, int w, int h) {
	roi.x += x;
	roi.y += y;
	roi.w += w;
	roi.h += h;
}

/// adjust the rectangle position and size
inline adjust(Rect roi&, int w, int h) = roi.adjust(-w, -h, 2 * w, 2 * h);

/// adjust the rectangle position and size
inline adjust(Rect roi&, int s) = roi.adjust(-s, -s, 2 * s, 2 * s);

///@public
bool clip(Image image, Rect roi&) {

	roi.w += roi.x;
	roi.h += roi.y;

	if (roi.x < 0) {
		roi.x = 0;
	}

	if (roi.y < 0) {
		roi.y = 0;
	}

	int width = image.width();
	if (roi.w > width) {
		roi.w = width;
	}

	int height = image.height();
	if (roi.h > height) {
		roi.h = height;
	}

	roi.w -= roi.x;
	roi.h -= roi.y;

	if (roi.w <= 0) {
		return false;
	}
	if (roi.h <= 0) {
		return false;
	}
	return true;
}

/// Set the the color of a pixel at the given position
inline set(Image image, int32 x, int32 y, argb color) = Image.set(image, x, y, uint32(color));

