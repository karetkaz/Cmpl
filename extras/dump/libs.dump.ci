Layout.getPressed(this: Layout): View: function {
.kind: static function
.base: `function`
.size: 114
.name: 'getPressed'
.file: 'cmplGfx/lib/micro.ui.core.ci:387'
.owner: Layout
.param .result: View (size: 4, cast: variable(ref))
.param this: Layout (size: 4, cast: const variable(ref))
.value: {
	if (this.pressedIndex < 0) {
		return .result := null;
	}
	selected: View := this.items[this.pressedIndex].view;
	if ((layout) != null) {
		view: View := getPressed(layout);
		if ((view) != null) {
			return .result := view;
		}
	}
	return .result := selected;
}
