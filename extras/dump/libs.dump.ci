.doc: 'copy the `src` image to the destination with the given transparency'
.value: {
	static if ((preferNativeCalls) && (typename(Image.blend.alpha)) != null) {
		return .result := Image.blend(image, x, y, src, roi, alpha, Image.blend.alpha);
