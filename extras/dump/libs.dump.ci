Layout.horizontalLayout(this: Layout, measured: Rect, rows: int32): void: function {
.kind: static function
.base: `function`
.size: 648
.name: 'horizontalLayout'
.file: 'cmplGfx/lib/micro.ui.core.ci:796'
.owner: Layout
.param .result: void (size: 0, cast: variable(void))
.param this: Layout (size: 4, cast: variable(ref))
.param measured: Rect (size: 4, cast: variable(ref))
.param rows: int32 (size: 4, cast: variable(i32))
.value: {
	colSpacing: int32 := measured.h / rows;
	rowSpacing: int32 := 0;
	grow: int32 := 0;
	if (true) {
		maxSize: int32 := 0;
		sumSize: int32 := 0;
		cols: int32 := 0;
		n: int32 := rows;
		for (i: int32 := 0; i < this.itemCount; i := i + 1) {
			rect: Rect := this.items[i].rect;
			if ((rect.w) && (rect.h)) {
				if (n >= rows) {
					sumSize := sumSize + maxSize;
					maxSize := 0;
					cols := cols + 1;
					n := 0;
				}
				if (maxSize < rect.w) {
					maxSize := rect.w;
				}
				if (rowSpacing < rect.w) {
					rowSpacing := rect.w;
				}
				n := n + 1;
			}
		}
		sumSize := sumSize + maxSize;
		if (cols > 0 && measured.w > sumSize) {
			grow := (measured.w - sumSize) / cols;
		}
	}
	r: Rect := {
		r.x := measured.x;
		r.y := measured.y;
		r.w := this.width > 0 ? this.width : measured.w;
		r.h := this.height > 0 ? this.height : measured.h;
	};
	n: int32 := rows;
	r.x := r.x - rowSpacing + grow;
	for (i: int32 := 0; i < this.itemCount; i := i + 1) {
		item: Item := this.items[i];
		rect: Rect := item.rect;
		if ((rect.w) && (rect.h)) {
			if (n >= rows) {
				r.y := measured.y;
				r.x := r.x + rowSpacing + grow;
				if (rows == 1) {
					rowSpacing := rect.w;
				}
				n := 0;
			}
			r.w := rowSpacing + grow;
			r.h := colSpacing;
			view: View := item.view;
			align: int32 := item.align;
			if (view.width > 0 && Style.vertical(align)) {
				align := align & ~Style.vertical;
			}
			if (view.height > 0 && Style.horizontal(align)) {
				align := align & ~Style.horizontal;
			}
			Style.align(r, &rect, align);
			if ((layout) != null) {
				layout.onLayout(layout, &rect);
			}
			r.y := r.y + colSpacing;
			n := n + 1;
		}
	}
}
