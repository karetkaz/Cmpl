	}
	static if ((typename(Image.openBmp)) != null) {
		if (endsWith(fileName, ".bmp", ignCaseCmp)) {
			return .result := Image.openBmp(fileName, depth);
		}
	}
	return .result := Image.openImg(fileName, depth);
}
