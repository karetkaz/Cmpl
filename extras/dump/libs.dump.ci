	if (exp > 1023) {
		return .result := copysign(inf, f);
	}
	m: float64 := 1;
	if (exp < -1022) {
		exp := exp + 53;
		m := (1) / float64(1 << 53);
	}
	x := x & ~(mask << shift);
	x := x | uint64(exp + bias) << shift;
	return .result := m * Bits.asFloat64(x);
}
