.doc: '@public'
.value: {
	r: float64 := abs(a);
	t: float64 := arg(a);
	u: float64 := b.re * t + b.im * Math.log(r);
	v: float64 := Math.pow(r, b.re) * Math.exp(-b.im * t);
	return .result := {
			.result.re := v * Math.cos(u);
			.result.im := v * Math.sin(u);
		};
}
