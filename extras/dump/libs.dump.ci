.doc: 'read and process c style format flags like: "%02d"'
.value: {
	chr: int32 := format[pos];
	if (chr != ('%')) {
		return .result := {
			.result.padLen := 0;
			.result.padChr := (0);
			.result.precision := 0;
			.result.sign := (0);
		};
	}
	pos := pos + 1;
	chr := (format[pos]);
	if (chr == ('%')) {
		return .result := {
			.result.padLen := 0;
			.result.padChr := (0);
			.result.precision := 0;
			.result.sign := (0);
		};
