clip(image: Image, roi: Rect): bool: function {
.kind: static function
.base: `function`
.size: 235
.name: 'clip'
.file: 'cmplGfx/gfxlib.ci:19'
.param .result: bool (size: 4, cast: variable(bool))
.param image: Image (size: 8, cast: variable(val))
.param roi: Rect (size: 4, cast: variable(ref))
.doc: '@public'
.value: {
	roi.w := roi.w + roi.x;
	roi.h := roi.h + roi.y;
	if (roi.x < 0) {
		roi.x := 0;
	}
	if (roi.y < 0) {
		roi.y := 0;
	}
	width: int32 := Image.width(image);
	if (roi.w > width) {
		roi.w := width;
	}
	height: int32 := Image.height(image);
	if (roi.h > height) {
		roi.h := height;
	}
	roi.w := roi.w - roi.x;
	roi.h := roi.h - roi.y;
	if (roi.w <= 0) {
		return .result := false;
	}
	if (roi.h <= 0) {
		return .result := false;
	}
	return .result := true;
}
