			panel.onTouchEvent := onTouchEvent;
			panel.onMeasure := onMeasure;
			panel.onDraw := onDraw;
		};
		this.states[0] := ("<");
		this.states[1] := ("^");
		this.header := (header);
		this.panel := panel;
		Layout.addItems(this, align, header, panel);
