	}
	if (cols > 1) {
		sumHeight := maxHeight * rows;
	}
	measured.w := sumWidth + this.paddingLeft + this.paddingRight;
	measured.h := sumHeight + this.paddingTop + this.paddingBottom;
	return .result := View.onMeasure(this, &measured);
}
