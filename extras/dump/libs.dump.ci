				camera: Camera := data.cam;
				shift: bool := bool((ey) & Window.KEY_MASK_SHIFT);
				Camera.rotate(camera, camera.position, camera.up, +(shift ? fast : slow));
				Data.updateCamera(data);
			}
			else if (button == ('l')) {
