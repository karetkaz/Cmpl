.doc: 'pow2(x) <=> 2 ** x
pow2(x) = pow2(n + q) = pow2(n) * pow2(q)
let n = floor(x);
 let q = fract(x);
 pow2(n) = 2 ** n = 1 << n
pow2(q) = 1 + look up from table
pow2(x) = (x >= 0) ? (pow2(q) << n) : (pow2(q) >> -n)
