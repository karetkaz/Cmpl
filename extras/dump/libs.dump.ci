		rows: int32 := 0;
		n: int32 := cols;
		for (i: int32 := 0; i < this.itemCount; i := i + 1) {
			rect: Rect := this.items[i].rect;
			if ((rect.w) && (rect.h)) {
				if (n >= cols) {
					sumSize := sumSize + maxSize;
					maxSize := 0;
					rows := rows + 1;
					n := 0;
				}
				if (maxSize < rect.h) {
