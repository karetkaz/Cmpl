		if ((rect.w) && (rect.h)) {
			if (n >= rows) {
				r.y := measured.y;
				r.x := r.x + rowSpacing + grow;
				if (rows == 1) {
					rowSpacing := rect.w;
				}
				n := 0;
			}
			r.w := rowSpacing + grow;
			r.h := colSpacing;
			view: View := item.view;
			align: int32 := item.align;
			if (view.width > 0 && Style.vertical(align)) {
