		const onDestroy(this: View): void := onDestroy;
		static onKeyEvent(this: View, const event: KeyEvent): bool := {
			if (!this.enabled) {
				return .result := false;
			}
			if (event.release) {
				return .result := false;
			}
			if (event.key == (' ')) {
				return .result := this.onClick(this);
			}
			if ((event.key) == Gui.KEY_CODE_BACK) {
