TabPage.onClickTab(button: Button): bool: function {
.kind: static function
.base: `function`
.size: 138
.name: 'onClickTab'
.file: 'cmplGfx/lib/micro.ui.ci:644'
.owner: TabPage
.param .result: bool (size: 4, cast: variable(bool))
.param button: Button (size: 4, cast: variable(ref))
.value: {
	if ((page) != null) {
		if ((tabs) != null) {
			if (tabs.active == page) {
				return .result := false;
			}
			tabs.active := page;
			invalidate(tabs);
			focus(page);
		}
	}
	return .result := true;
}
