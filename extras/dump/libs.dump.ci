.value: {
	colSpacing: int32 := measured.h / rows;
	rowSpacing: int32 := 0;
	grow: int32 := 0;
	if (true) {
		maxSize: int32 := 0;
		sumSize: int32 := 0;
		cols: int32 := 0;
		n: int32 := rows;
		for (i: int32 := 0; i < this.itemCount; i := i + 1) {
			rect: Rect := this.items[i].rect;
			if ((rect.w) && (rect.h)) {
				if (n >= rows) {
					sumSize := sumSize + maxSize;
					maxSize := 0;
					cols := cols + 1;
					n := 0;
				}
				if (maxSize < rect.w) {
					maxSize := rect.w;
				}
				if (rowSpacing < rect.w) {
					rowSpacing := rect.w;
				}
				n := n + 1;
			}
