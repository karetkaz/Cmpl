.value: {
	dir: int32 := this.orientation;
	N: int32 := Math.abs(dir);
	n: int32 := 0;
	maxWidth: int32 := 0;
	sumWidth: int32 := 0;
	maxHeight: int32 := 0;
	sumHeight: int32 := 0;
	rows: int32 := dir < 0 ? N : 1;
	cols: int32 := dir > 0 ? N : 1;
