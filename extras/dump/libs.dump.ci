	padLen: int32 := 0;
	for ( ; chr >= ('0') && chr <= ('9'); ) {
		pos := pos + 1;
		padLen := padLen * 10 + chr - ('0');
		chr := (format[pos]);
	}
	precision: int32 := 0;
	if (chr == ('.')) {
		pos := pos + 1;
		chr := (format[pos]);
		for ( ; chr >= ('0') && chr <= ('9'); ) {
			pos := pos + 1;
			precision := precision * 10 + chr - ('0');
			chr := (format[pos]);
		}
	}
	return .result := {
			.result.sign := (sgnChr);
			.result.padChr := (padChr);
			.result.padLen := padLen;
			.result.precision := precision;
		};
}
