Layout.verticalLayout(this: Layout, measured: Rect, cols: int32): void: function {
.kind: static function
.base: `function`
.size: 633
.name: 'verticalLayout'
.file: 'cmplGfx/lib/micro.ui.core.ci:713'
.owner: Layout
.param .result: void (size: 0, cast: variable(void))
.param this: Layout (size: 4, cast: variable(ref))
.param measured: Rect (size: 4, cast: variable(ref))
.param cols: int32 (size: 4, cast: variable(i32))
.value: {
	rowSpacing: int32 := measured.w / cols;
	colSpacing: int32 := 0;
	grow: int32 := 0;
	if (true) {
		maxSize: int32 := 0;
		sumSize: int32 := 0;
		rows: int32 := 0;
		n: int32 := cols;
		for (i: int32 := 0; i < this.itemCount; i := i + 1) {
			rect: Rect := this.items[i].rect;
			if ((rect.w) && (rect.h)) {
				if (n >= cols) {
					sumSize := sumSize + maxSize;
					maxSize := 0;
					rows := rows + 1;
					n := 0;
				}
				if (maxSize < rect.h) {
					maxSize := rect.h;
				}
				if (colSpacing < maxSize) {
					colSpacing := maxSize;
				}
				n := n + 1;
			}
		}
		sumSize := sumSize + maxSize;
		if (rows > 0 && measured.h > sumSize) {
			grow := (measured.h - sumSize) / rows;
		}
	}
	r: Rect := {
		r.x := measured.x;
		r.y := measured.y;
		r.w := this.width > 0 ? this.width : measured.w;
		r.h := this.height > 0 ? this.height : measured.h;
	};
	n: int32 := cols;
	r.y := r.y - colSpacing + grow;
	for (i: int32 := 0; i < this.itemCount; i := i + 1) {
		item: Item := this.items[i];
		rect: Rect := item.rect;
		if ((rect.w) && (rect.h)) {
			if (n >= cols) {
				r.x := measured.x;
				r.y := r.y + colSpacing + grow;
				if (cols == 1) {
					colSpacing := rect.h;
				}
				n := 0;
			}
			r.w := rowSpacing;
			r.h := colSpacing + grow;
			view: View := item.view;
			align: int32 := item.align;
			if (view.width > 0 && Style.vertical(align)) {
				align := align & ~Style.vertical;
			}
			if (view.height > 0 && Style.horizontal(align)) {
				align := align & ~Style.horizontal;
			}
			Style.align(r, &rect, align);
			if ((layout) != null) {
				layout.onLayout(layout, &rect);
			}
			r.x := r.x + rowSpacing;
			n := n + 1;
		}
	}
}
