Widget.focusNext(view: View, prev: bool): bool: function {
.kind: static function
.base: `function`
.size: 529
.name: 'focusNext'
.file: 'cmplGfx/lib/micro.ui.core.ci:983'
.owner: Widget
.param .result: bool (size: 4, cast: variable(bool))
.param view: View (size: 4, cast: variable(ref))
.param prev: bool (size: 4, cast: variable(bool))
.value: {
	if ((view) == null) {
		return .result := false;
	}
	if (!view.enabled) {
		return .result := false;
	}
	if (!view.focusable) {
		return .result := false;
	}
	this: Layout := as(view, Layout);
	if ((this) == null) {
		return .result := true;
	}
	n: int32 := this.focusedIndex;
	if (prev) {
		if (n < 0) {
			n := this.itemCount - 1;
		}
		for (i: int32 := n; i >= 0; i := i - 1) {
			const item: Item := this.items[i];
			const rect: Rect := item.rect;
			const view: View := item.view;
			if ((rect.w) && (rect.h) && focusNext(view, prev)) {
				if (as(view, Layout) != null || i != this.focusedIndex) {
					this.focusedIndex := i;
					return .result := true;
				}
			}
		}
	}
	else {
		if (n < 0) {
			n := 0;
		}
		for (i: int32 := n; i < this.itemCount; i := i + 1) {
			const item: Item := this.items[i];
			const rect: Rect := item.rect;
			const view: View := item.view;
			if ((rect.w) && (rect.h) && focusNext(view, prev)) {
				if (as(view, Layout) != null || i > this.focusedIndex) {
					this.focusedIndex := i;
					return .result := true;
				}
			}
		}
	}
	clearState(this, Style.focused);
	return .result := false;
}
.instructions: (529 bytes)
