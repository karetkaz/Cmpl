			panel.onLayout := onLayout;
			panel.width := -5;
			panel.height := -5;
			panel.enabled := true;
			panel.focusable := true;
			panel.parent := (null);
			panel.style := (null);
			panel.data := (null);
			panel.onClick := onClick;
			panel.onReset := onReset;
