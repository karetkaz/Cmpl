.value: {
	assert((this.parent) == null || this.parent == parent, "can not add the same view to different layouts");
	this.parent := parent;
	if ((this.style) == null) {
		assert((parent.style) != null, "can not create view with a parent without a style");
		this.style := emit(pointer(parent.style));
	}
}
