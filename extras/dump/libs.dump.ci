	rect: Rect := {
		rect.x0 := 0;
		rect.y0 := 0;
		rect.x1 := 0;
		rect.y1 := 0;
	};
	widget.onMeasure(widget, &rect);
	clearFocus(widget);
	Widget.setFocused(widget, view);
	Widget.focusNext(widget, false);
	widget.measure := true;
}
