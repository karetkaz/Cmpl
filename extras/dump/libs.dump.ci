Layout.onLayout(this: Layout, measured: Rect): void: function {
.kind: static function
.base: `function`
.size: 540
.name: 'onLayout'
.file: 'cmplGfx/lib/micro.ui.core.ci:879'
.owner: Layout
.param .result: void (size: 0, cast: variable(void))
.param this: Layout (size: 4, cast: variable(ref))
.param measured: Rect (size: 4, cast: variable(ref))
.value: {
	padd(rect: Rect, t: int32, l: int32, r: int32, b: int32): void := adjust(&rect, -l, -t, l + r, t + b);
	padd(measured, -this.paddingTop, -this.paddingLeft, -this.paddingRight, -this.paddingBottom);
	if (this.orientation > 0) {
		verticalLayout(this, &measured, this.orientation);
		padd(measured, this.paddingTop, this.paddingLeft, this.paddingRight, this.paddingBottom);
		return;
	}
	if (this.orientation < 0) {
		horizontalLayout(this, &measured, -this.orientation);
		padd(measured, this.paddingTop, this.paddingLeft, this.paddingRight, this.paddingBottom);
		return;
	}
	r: Rect := {
		r.x := measured.x;
		r.y := measured.y;
		r.w := this.width > 0 ? this.width : measured.w;
