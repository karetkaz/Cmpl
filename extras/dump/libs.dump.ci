			}
			sumHeight := sumHeight + height;
			if (maxHeight < height) {
				maxHeight := height;
			}
			n := n + 1;
		}
	}
	if (rows == 1 && cols == 1) {
		sumWidth := maxWidth;
		sumHeight := maxHeight;
	}
	if (rows > 1) {
