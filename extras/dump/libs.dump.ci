		rect.y0 := 0;
		rect.x1 := 0;
		rect.y1 := 0;
	};
	widget.onCreate(widget, widget);
	widget.onMeasure(widget, &rect);
	offscreen: Image := Image(width(rect), height(rect), 32);
	show(offscreen, widget);
	Image.destroy(offscreen);
}
