			.result.zx := xz * k - y * s;
			.result.zy := yz * k + x * s;
			.result.zz := zz + (xx + yy) * c;
			.result.zw := (cz * (xx + yy) - z * (cx * x + cy * y)) * k + (cx * y - cy * x) * s;
			.result.w := vec4f(0, 0, 0, 1);
		};
}
