.param .result: bool (size: 4, cast: variable(bool))
.param x: Fixed (size: 8, cast: variable(val))
.doc: 'Determines whether the given fixed point value is finite: `!isNan(x) && !isInf(x)`'
.value: {
	if (x.value == nan) {
		return .result := false;
	}
	if (x.value == inf) {
		return .result := false;
	}
	if (x.value == -inf) {
		return .result := false;
	}
	return .result := true;
}
