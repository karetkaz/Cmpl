Math.sincos(x: float64, quad: int32): float64: function {
.kind: static function
.base: `function`
.size: 357
.name: 'sincos'
.file: 'cmplStd/lib/math/Math.ci:700'
.owner: Math
.param .result: float64 (size: 8, cast: variable(f64))
.param x: float64 (size: 8, cast: variable(f64))
.param quad: int32 (size: 4, cast: variable(i32))
.value: {
	if (x < (0)) {
		x := -x;
		quad := quad + 2;
	}
	y: float64;
	x := x * (2) / pi;
	if (x > (32764)) {
		e: float64;
		y := modf(x, &e);
		e := e + (quad);
		f: float64;
		modf(0.250000 * e, &f);
		quad := (e - (4) * f);
	}
	else {
		k: int32 := x;
		y := x - (k);
		quad := quad + k;
		quad := quad & 3;
	}
	if (quad & 1) {
		y := (1) - y;
	}
	if (quad > 1) {
		y := -y;
	}
	ysq: float64 := y * y;
	p: float64 := y * eval(ysq, p0, p1, p2, p3, p4);
	q: float64 := eval(ysq, q0, q1, q2, q3 + ysq);
	return .result := p / q;
}
