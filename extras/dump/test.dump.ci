	if (x > MAXLOG) {
		return .result := inf;
	}
	if (x < MINLOG) {
		return .result := 0;
	}
	px: float64 := floor(LOG2E * x + 0.500000);
	x := x - px * c1;
	x := x - px * c2;
	xx: float64 := x * x;
	p: float64 := x * eval(xx, p2, p1, p0);
	q: float64 := eval(xx, q3, q2, q1, q0);
	return .result := ldexp((1) + (2) * p / (q - p), px);
}
