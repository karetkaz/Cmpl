	first: bool := true;
	for (i: int32 := this.capacity - 1; i >= 0; i := i - 1) {
		if (this.coefficients[i] == c_zero && !(first && i == 0)) {
			continue;
		}
		value: float64 := this.coefficients[i];
		if (value < c_zero) {
			value := -value;
			if (!first) {
				TextWriter.write(writer, " - ");
			}
			else {
				TextWriter.write(writer, "-");
			}
		}
		else if (!first) {
			TextWriter.write(writer, " + ");
		}
		if (value != c_unit || i == 0) {
			write(writer, value);
		}
		if (i > 0) {
			TextWriter.write(writer, "x");
			if (i > 1) {
				TextWriter.write(writer, "^");
				write(writer, i);
			}
		}
		first := false;
	}
}
