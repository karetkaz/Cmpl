Datetime.format(value: Datetime, output: char[], end: int32, format: char[]): int32: function {
.kind: static function
.base: `function`
.size: 2259
.name: 'format'
.file: 'cmplStd/lib/time/Datetime.ci:147'
.owner: Datetime
.param .result: int32 (size: 4, cast: variable(i32))
.param value: Datetime (size: 4, cast: const variable(ref))
.param output: char[] (size: 8, cast: variable(arr))
.param end: int32 (size: 4, cast: variable(i32))
.param format: char[] (size: 8, cast: const variable(arr))
.value: {
	static const weekDayNames: char[][] := {
		weekDayNames := weekDayNames.init;
		weekDayNames.init[0] := ("Monday");
		weekDayNames.init[1] := ("Tuesday");
		weekDayNames.init[2] := ("Wednesday");
		weekDayNames.init[3] := ("Thursday");
		weekDayNames.init[4] := ("Friday");
		weekDayNames.init[5] := ("Saturday");
		weekDayNames.init[6] := ("Sunday");
	};
	static const monthNames: char[][] := {
		monthNames := monthNames.init;
		monthNames.init[0] := ("January");
		monthNames.init[1] := ("February");
		monthNames.init[2] := ("March");
		monthNames.init[3] := ("April");
		monthNames.init[4] := ("May");
		monthNames.init[5] := ("June");
		monthNames.init[6] := ("July");
		monthNames.init[7] := ("August");
		monthNames.init[8] := ("September");
		monthNames.init[9] := ("October");
		monthNames.init[10] := ("November");
		monthNames.init[11] := ("December");
	};
	hours24to12(hour: int32): int32 := hour > 12 ? hour - 12 : hour == 0 ? 12 : hour;
	if (pointer(format) == null) {
		return .result := format(value, output, end, "%Y.%m.%d");
	}
	chr: char := 0;
	for (pos: int32 := 0; pos < (format.length); pos := pos + 1) {
		if (end >= (output.length)) {
			output[output.length - (1)] := (0);
			return .result := output.length - (1);
		}
		chr := format[pos];
		if (chr != '%') {
			output[end] := chr;
			end := end + 1;
			continue;
		}
		flags: FormatFlags := FormatFlags.read(format, &pos);
		chr := format[pos];
		if (chr == '%') {
			end := append(output, end, "%");
		}
		else if (chr == 'A') {
			end := append(output, end, weekDayNames[indexOf(value.dayOfWeek)]);
		}
		else if (chr == 'B') {
			end := append(output, end, monthNames[indexOf(value.month)]);
		}
		else if (chr == 'C') {
			end := append(output, end, value.year / 100, FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 'd') {
			end := append(output, end, value.day, FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 'D') {
			end := format(value, output, end, "%m/%d/%y");
		}
		else if (chr == 'e') {
			end := append(output, end, value.day, FormatFlags.defPad(flags, 2, ' '));
		}
		else if (chr == 'F') {
			end := format(value, output, end, "%04Y-%m-%d");
		}
		else if (chr == 'H') {
			end := append(output, end, value.hour, FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 'I') {
			end := append(output, end, hours24to12(value.hour), FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 'j') {
			end := append(output, end, value.dayOfYear, FormatFlags.defPad(flags, 3, '0'));
		}
		else if (chr == 'k') {
			end := append(output, end, value.hour, FormatFlags.defPad(flags, 2, ' '));
		}
		else if (chr == 'l') {
			end := append(output, end, hours24to12(value.hour), FormatFlags.defPad(flags, 2, ' '));
		}
		else if (chr == 'm') {
			end := append(output, end, indexOf(value.month) + 1, FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 'M') {
			end := append(output, end, value.minute, FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 'n') {
			end := append(output, end, "\n");
		}
		else if (chr == 'N') {
			end := append(output, end, (value.millis) * 1000000, FormatFlags.defPad(flags, 9, '0'));
		}
		else if (chr == 'p') {
			end := append(output, end, (value.hour) < 12 ? "AM" : "PM");
		}
		else if (chr == 'P') {
			end := append(output, end, (value.hour) < 12 ? "am" : "pm");
		}
		else if (chr == 'R') {
			end := format(value, output, end, "%H:%M");
		}
		else if (chr == 'S') {
			end := append(output, end, value.second, FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 't') {
			end := append(output, end, "\t");
		}
		else if (chr == 'T') {
			end := format(value, output, end, "%H:%M:%S");
		}
		else if (chr == 'u') {
			end := append(output, end, indexOf(value.dayOfWeek) + 1, flags);
		}
		else if (chr == 'W') {
			end := append(output, end, value.weekOfYear, FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 'y') {
			end := append(output, end, value.year % 100, FormatFlags.defPad(flags, 2, '0'));
		}
		else if (chr == 'Y') {
			end := append(output, end, value.year, flags);
		}
		else {
			abort("unimplemented or invalid format character", chr);
		}
	}
	if (end >= (output.length)) {
		end := (output.length - (1));
	}
	output[end] := (0);
	return .result := end;
}
