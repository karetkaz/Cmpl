Timestamp.floor(value: Timestamp, precision: Timeunit): Timestamp: function {
.kind: static function
.base: `function`
.size: 94
.name: 'floor'
.file: 'cmplStd/lib/time/Timestamp.ci:50'
.owner: Timestamp
