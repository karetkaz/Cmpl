			}
			float64(decimal := (1));
		}
		else if (bool(bool(chr == '-') && bool(i == 0))) {
			float64(sign := (int32(-1)));
		}
		else if (bool(bool(chr == '+') && bool(i == 0))) {
			float64(sign := (1));
		}
		else {
