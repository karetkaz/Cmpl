Math.tanCot(x: float64, flag: int32): float64: function {
.kind: static function
.base: `function`
.size: 476
.offset: <@065570>
.name: 'tanCot'
.file: 'cmplStd/lib/math/Math.ci:363'
.owner: Math
.param .result: float64 (size: 8, offs: <+8>, cast: variable(f64))
.param x: float64 (size: 8, offs: <+16>, cast: variable(f64))
.param flag: int32 (size: 4, offs: <+20>, cast: variable(i32))
.value: {
	sign: float64 := 1;
	if (bool(x < (0))) {
		float64(x := float64(-x));
		float64(sign := (int32(-1)));
	}
	if (bool(x > 1073741824.000000)) {
		error("total loss of precision");
		return int32(.result := 0);
	}
	y: float64 := floor(float64(x / PIO4));
	z: float64 := ldexp(void(y, int32(-3)));
	float64(z := floor(z));
	float64(z := float64(y - ldexp(void(z, 3))));
	j: int32 := z;
	if (int32(j & 1)) {
		int32(j := int32(j + 1));
