Math.cmp(a: float32, b: float32, eps: float32): int32: function {
.kind: static function
.base: `function`
.size: 57
.offset: <@062730>
.name: 'cmp'
.file: 'cmplStd/lib/math/Math.ci:269'
.owner: Math
.param .result: int32 (size: 4, offs: <+4>, cast: variable(i32))
