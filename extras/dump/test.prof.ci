Math.floor(x: float64): float64: function {
.kind: static function
.base: `function`
.size: 42
.offset: <@063ce0>
.name: 'floor'
.file: 'cmplStd/lib/math/Math.ci:47'
.owner: Math
.param .result: float64 (size: 8, offs: <+8>, cast: variable(f64))
.param x: float64 (size: 8, offs: <+16>, cast: variable(f64))
