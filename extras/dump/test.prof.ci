.param x: float64 (size: 8, offs: <+16>, cast: variable(f64))
.doc: 'Returns the tangent of the radian argument `x`.'
.value: {
	static if (bool(true && bool((typename(float64.tan)) != null))) {
		return float64(.result := float64.tan(x));
