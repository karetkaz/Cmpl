.param value: char[] (size: 8, offs: <+16>, cast: const variable(arr))
.doc: 'Convert a string to a 64 bit floating point value'
.value: {
	sign: float64 := 1;
	result: float64 := 0;
	decimal: float64 := 0;
	for (i: int32 := 0; bool(bool(i < (value.length)) && bool((value[i]) != 0)); int32(i := int32(i + 1))) {
