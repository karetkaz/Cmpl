FormatFlags.defPad(this: FormatFlags, padLen: int32, padChr: char): FormatFlags: function {
.kind: static function
.base: `function`
.size: 50
.offset: <@066460>
.name: 'defPad'
.file: 'cmplStd/lib/text/cstr.ci:187'
.owner: FormatFlags
.param .result: FormatFlags (size: 16, offs: <+16>, cast: variable(val))
.param this: FormatFlags (size: 4, offs: <+20>, cast: const variable(ref))
.param padLen: int32 (size: 4, offs: <+24>, cast: variable(i32))
.param padChr: char (size: 4, offs: <+28>, cast: variable(i32))
.doc: 'override the default padding, in case it's length is zero'
.value: {
	if (bool(this.padLen == 0)) {
		return void(.result := {
			void(.result.sign := this.sign);
			void(.result.precision := this.precision);
			void(.result.padChr := padChr);
			void(.result.padLen := padLen);
		});
	}
	return FormatFlags(.result := this);
}
